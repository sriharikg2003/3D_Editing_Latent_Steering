#!/usr/bin/env python3
"""
CLI entry point for 3D mask creation.

Usage
-----
python create_mask \
    --render_dir  /path/to/render_output \
    --prompt      "the horn on the helmet" \
    --output_dir  /path/to/save/mask \
    --dilation    4
"""

import argparse
import sys
import os

sys.path.insert(0, os.path.dirname(__file__))

from inference.create_mask import create_mask_3d


def parse_args():
    p = argparse.ArgumentParser(
        description="Create a 3D voxel mask from a text prompt applied to a rendered front view."
    )
    p.add_argument(
        "--render_dir", required=True,
        help="Directory with front.png and front_metadata.json (output of render_views.py).",
    )
    p.add_argument(
        "--prompt", required=True,
        help="Text description of the region to mask, e.g. 'the tail of the dragon'.",
    )
    p.add_argument(
        "--output_dir", default=None,
        help="Where to save mask outputs (defaults to --render_dir).",
    )
    p.add_argument(
        "--front_image", default="front.png",
        help="Filename of the rendered front-view image (default: front.png).",
    )
    p.add_argument(
        "--device", default="cuda",
        help="PyTorch device (default: cuda).",
    )
    p.add_argument(
        "--score_threshold", type=float, default=0.1,
        help="Minimum OWLv2 detection confidence (default: 0.1).",
    )
    p.add_argument(
        "--grid_size", type=int, default=64,
        help="Voxel grid side length (default: 64).",
    )
    p.add_argument(
        "--dilation", type=int, default=4,
        help=(
            "Expand the mask outward by this many voxels in every direction. "
            "Higher values give more room for the object to grow into adjacent "
            "empty space (default: 4)."
        ),
    )
    return p.parse_args()


def main():
    args = parse_args()

    result = create_mask_3d(
        render_dir       = args.render_dir,
        text_prompt      = args.prompt,
        output_dir       = args.output_dir,
        front_image_name = args.front_image,
        device           = args.device,
        score_threshold  = args.score_threshold,
        grid_size        = args.grid_size,
        dilation_voxels  = args.dilation,
    )

    print("\n── Outputs ──────────────────────────────────────────────────")
    for k, v in result.items():
        print(f"  {k:<22} {v}")


if __name__ == "__main__":
    main()
